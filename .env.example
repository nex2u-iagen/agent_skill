# Telegram Bot Token
TELEGRAM_BOT_TOKEN=seu_token_aqui

# LLM Providers Keys and Models
GEMINI_MODEL=models/gemini-2.0-flash-lite-001
GEMINI_API_KEY=sua_chave_gemini

GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=sua_chave_groq

# Anthropic (Claude)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sua_chave_anthropic

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sua_chave_deepseek

# OpenRouter (opcional)
OPENROUTER_API_KEY=sua_chave_openrouter

# Configuration
DEFAULT_PROVIDER=gemini
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=10
PORT=3000

# SQLite File Path
DB_PATH=./data/Agente_Skill_Trabalho.sqlite

# ==========================================
# Google APIs (Agenda / Calendar) - REMOVIDO
# ==========================================
# Google Calendar foi removido do projeto.

# ==========================================
# Whisper Local (Transcrição de Áudio) - Opcional
# ==========================================
# WHISPER_BASE_URL=http://localhost:8000/v1
# WHISPER_API_KEY=local-key

# ==========================================
# TTS Local (Síntese de Áudio) - Opcional
# ==========================================
# TTS_BASE_URL=http://localhost:8000/v1
# TTS_API_KEY=local-key

# ==========================================
# Google APIs (Agenda / Calendar) - Opcional
# ==========================================
# Para usar as tools de Google Calendar, crie uma Service Account no Google Cloud Platform
# e preencha as credenciais abaixo. Se não usar Google Calendar, deixe em branco.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary